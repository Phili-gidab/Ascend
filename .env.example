# --- Contact form (optional, no backend required) ---
# Works with any "no-backend" form service (Web3Forms, Formspree, etc.).
# Copy this file to `.env` (or set these in Vercel → Settings → Environment Variables).
# Leave them blank to have the form open the visitor's email client instead.
#
# Example with Web3Forms (https://web3forms.com — free):
#   VITE_FORM_ENDPOINT=https://api.web3forms.com/submit
#   VITE_FORM_KEY=your-access-key
#
# Example with Formspree (https://formspree.io):
#   VITE_FORM_ENDPOINT=https://formspree.io/f/your-form-id
#   (no key needed)
VITE_FORM_ENDPOINT=
VITE_FORM_KEY=
